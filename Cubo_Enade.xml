        </Level>
      </Hierarchy>
    </Dimension>
    <Dimension type="StandardDimension" visible="true" foreignKey="id_curso" highCardinality="false" name="Curso">
      <Hierarchy name="Geografia_Curso" visible="true" hasAll="true" allMemberName="Todos os Cursos">
